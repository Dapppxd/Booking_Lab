<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:text="Tambah Jadwal"
        android:textAlignment="center"
        android:textColor="@color/main_color"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Pilih Laboratorium:"
        android:textColor="@color/main_color"
        android:textSize="14sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerNamaLab"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_input_gray"
        android:paddingStart="20dp"
        android:paddingEnd="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Tanggal:"
        android:textColor="@color/main_color"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etTanggalAdmin"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_input_gray"
        android:hint="Pilih Tanggal"
        android:focusable="false"
        android:clickable="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColorHint="#BDBDBD" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Waktu:"
        android:textColor="@color/main_color"
        android:textSize="14sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinnerWaktuAdmin"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_input_gray"
        android:paddingStart="20dp"
        android:paddingEnd="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSimpanLab"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Simpan Jadwal"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:backgroundTint="@color/main_color"
        app:cornerRadius="28dp" />

</LinearLayout>